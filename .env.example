# ==================================================
# Django Configuration
# ==================================================
DJANGO_ENV=development
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ==================================================
# Database (PostgreSQL + PostGIS)
# ==================================================
POSTGRES_DB=fire_detection
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password-here
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ==================================================
# Redis / Celery
# ==================================================
REDIS_HOST=redis
REDIS_PORT=6379
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ==================================================
# Email Configuration (Gmail SMTP)
# ==================================================
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password

# ==================================================
# GDAL Configuration (Linux/Docker only)
# ==================================================
GDAL_LIBRARY_PATH=/usr/lib/x86_64-linux-gnu/libgdal.so.36

# ==================================================
# MQTT/TTN Configuration (if using)
# ==================================================
TTN_API_KEY=your-ttn-api-key-here

# ==================================================
# Logging Configuration (optional)
# ==================================================
# Log levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
DJANGO_LOG_LEVEL=INFO
DB_LOG_LEVEL=WARNING
CELERY_LOG_LEVEL=INFO
APP_LOG_LEVEL=DEBUG
ROOT_LOG_LEVEL=INFO

# ==================================================
# Optional: CSRF Trusted Origins (for production)
# ==================================================
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

